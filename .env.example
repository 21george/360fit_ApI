APP_ENV=development
APP_URL=http://localhost:8000

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=CoachingPlatform
MONGO_DB=coaching_platform

# JWT — generate with: openssl rand -hex 40
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# Coach Cap (overridden by subscription tier)
MAX_CLIENTS_PER_COACH=50

# CORS
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Mail
APP_NAME=CoachPro
MAIL_FROM=noreply@coachpro.app
MAIL_FROM_NAME=CoachPro
MAIL_DOMAIN=coachpro.app

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Pro tier price IDs (monthly, quarterly, semi-annual, annual)
STRIPE_PRICE_PRO=price_pro_monthly
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly
STRIPE_PRICE_PRO_QUARTERLY=price_pro_quarterly
STRIPE_PRICE_PRO_SEMI_ANNUAL=price_pro_semi_annual
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual

# Business tier price IDs (monthly, quarterly, semi-annual, annual)
STRIPE_PRICE_BUSINESS=price_business_monthly
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly
STRIPE_PRICE_BUSINESS_QUARTERLY=price_business_quarterly
STRIPE_PRICE_BUSINESS_SEMI_ANNUAL=price_business_semi_annual
STRIPE_PRICE_BUSINESS_ANNUAL=price_business_annual

STRIPE_SUCCESS_URL=http://localhost:3000/subscription/success
STRIPE_CANCEL_URL=http://localhost:3000/subscription/cancel

# FCM (v1 API — path to service account JSON)
FCM_SERVICE_ACCOUNT_PATH=
FCM_PROJECT_ID=

# Scheduled Notifications (cron job for reminders)
# Run every minute: * * * * * cd /path/to/backend && php scripts/send-reminders.php

# S3 / R2 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=eu-central-1
AWS_ENDPOINT=
